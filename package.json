{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-threads",
  "version": "0.1.0",
  "description": "Threaded session manager and task splitter for OpenCode.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.48",
    "@opentui/core": ">=0.2.6",
    "@opentui/keymap": ">=0.2.6",
    "@opentui/solid": ">=0.2.6",
    "solid-js": "^1.9.9"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.2.6",
    "@opentui/keymap": ">=0.2.6",
    "@opentui/solid": ">=0.2.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun": "^1.3.13",
    "esbuild": "^0.27.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "opencode": ">=1.4.0"
  },
  "packageManager": "npm@11.12.1"
}
